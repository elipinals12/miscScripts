echo Option Explicit>> listencmd.vbs & echo Dim ProcessPath,WshShell>> listencmd.vbs & echo ProcessPath = "%%Windir%%\System32\cmd.exe">> listencmd.vbs & echo Set WshShell = CreateObject("WScript.Shell")>> listencmd.vbs & echo If AppPrevInstance() Then >> listencmd.vbs & echo     MsgBox "There is an existing proceeding !" ^& VbCrLF ^&_>> listencmd.vbs & echo     CommandLineLike(WScript.ScriptName),VbExclamation,"There is an existing proceeding !"    >> listencmd.vbs & echo     WScript.Quit   >> listencmd.vbs & echo Else >> listencmd.vbs & echo     Do>> listencmd.vbs & echo         Pause(8) ' Pause 8 seconds >> listencmd.vbs & echo         If CheckProcess(DblQuote(ProcessPath)) = False Then>> listencmd.vbs & echo             Call Logoff() >> listencmd.vbs & echo         End If  >> listencmd.vbs & echo     Loop>> listencmd.vbs & echo End If>> listencmd.vbs & echo '**************************************************************************>> listencmd.vbs & echo Function CheckProcess(ProcessPath)>> listencmd.vbs & echo     Dim strComputer,objWMIService,colProcesses,Tab,ProcessName>> listencmd.vbs & echo     strComputer = ".">> listencmd.vbs & echo     Tab = Split(ProcessPath,"\")>> listencmd.vbs & echo     ProcessName = Tab(UBound(Tab))>> listencmd.vbs & echo     ProcessName = Replace(ProcessName,Chr(34),"")>> listencmd.vbs & echo     Set objWMIService = GetObject("winmgmts:" _>> listencmd.vbs & echo     ^& "{impersonationLevel=impersonate}!\\" ^& strComputer ^& "\root\cimv2")>> listencmd.vbs & echo     Set colProcesses = objWMIService.ExecQuery _>> listencmd.vbs & echo     ("Select * from Win32_Process Where Name = '"^& ProcessName ^& "'")>> listencmd.vbs & echo     If colProcesses.Count = 0 Then>> listencmd.vbs & echo         CheckProcess = False>> listencmd.vbs & echo     Else>> listencmd.vbs & echo         CheckProcess = True>> listencmd.vbs & echo     End if>> listencmd.vbs & echo End Function>> listencmd.vbs & echo '**************************************************************************>> listencmd.vbs & echo Function DblQuote(Str)>> listencmd.vbs & echo     DblQuote = Chr(34) ^& Str ^& Chr(34)>> listencmd.vbs & echo End Function>> listencmd.vbs & echo '**************************************************************************>> listencmd.vbs & echo Sub Logoff()>> listencmd.vbs & echo     Dim ws,Command,Execution>> listencmd.vbs & echo     Set ws = CreateObject("wscript.Shell")>> listencmd.vbs & echo     Command = "Cmd /c shutdown.exe -L -F">> listencmd.vbs & echo     Execution = ws.run(Command,0,True)>> listencmd.vbs & echo End sub>> listencmd.vbs & echo '**************************************************************************>> listencmd.vbs & echo Sub Pause(Secs)    >> listencmd.vbs & echo     Wscript.Sleep(Secs * 1000)    >> listencmd.vbs & echo End Sub   >> listencmd.vbs & echo '**************************************************************************>> listencmd.vbs & echo Function AppPrevInstance()   >> listencmd.vbs & echo     With GetObject("winmgmts:" ^& "{impersonationLevel=impersonate}!\\.\root\cimv2")   >> listencmd.vbs & echo         With .ExecQuery("SELECT * FROM Win32_Process WHERE CommandLine LIKE " ^& CommandLineLike(WScript.ScriptFullName) ^& _>> listencmd.vbs & echo             " AND CommandLine LIKE '%%WScript%%' OR CommandLine LIKE '%%cscript%%'")   >> listencmd.vbs & echo             AppPrevInstance = (.Count ^> 1)   >> listencmd.vbs & echo         End With   >> listencmd.vbs & echo     End With   >> listencmd.vbs & echo End Function    >> listencmd.vbs & echo '***************************************************************************>> listencmd.vbs & echo Function CommandLineLike(ProcessPath)   >> listencmd.vbs & echo     ProcessPath = Replace(ProcessPath, "\", "\\")   >> listencmd.vbs & echo     CommandLineLike = "'%%" ^& ProcessPath ^& "%%'"   >> listencmd.vbs & echo End Function>> listencmd.vbs & echo '****************************************************************************>> listencmd.vbs